# ============================================================
# EVERGREEN MANTRA — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- LLM (Groq) ---
GROQ_API_KEY="gsk_your_groq_api_key_here"

# --- Blockchain (Environment-Driven — swap chain without code changes) ---
WEB3_RPC_URL="https://rpc.sepolia.org"
WALLET_PRIVATE_KEY="0xYOUR_PRIVATE_KEY_HERE"

# Default: Sepolia Testnet. Change to 137 for Polygon, 80001 for Mumbai, etc.
WEB3_CHAIN_ID=11155111
BLOCKCHAIN_EXPLORER_URL="https://sepolia.etherscan.io/tx/"
